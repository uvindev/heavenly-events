# ==============================================================================
# Heavenly Events - Environment Variables
# ==============================================================================
# Copy this file to .env.local and fill in the values.

# --- Database ---
DATABASE_URL="postgresql://user:password@localhost:5432/heavenly_events?schema=public"

# --- Authentication ---
JWT_SECRET="your-jwt-secret-min-32-characters-long"
JWT_EXPIRES_IN="7d"

# --- SMTP / Email ---
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="noreply@example.com"
SMTP_PASSWORD="your-smtp-password"
SMTP_FROM_NAME="Heavenly Events"
SMTP_FROM_EMAIL="noreply@example.com"

# --- Google Maps ---
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# --- Analytics ---
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"
NEXT_PUBLIC_GTM_ID="GTM-XXXXXXX"

# --- Upload Settings ---
UPLOAD_DIR="./public/uploads"
UPLOAD_MAX_SIZE_MB=5
UPLOAD_ALLOWED_TYPES="image/jpeg,image/png,image/webp,image/avif"

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# --- Site Settings ---
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="Heavenly Events"
NODE_ENV="development"
