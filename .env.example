# ==============================================================================
# Heavenly Events - Environment Variables
# ==============================================================================
# Copy this file to .env.local and fill in the values.

# --- Database (Supabase PostgreSQL) ---
DATABASE_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-DB-PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:6432/postgres"
DIRECT_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-DB-PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:5432/postgres"

# --- Authentication ---
JWT_SECRET="generate-a-strong-random-string-at-least-32-characters"
JWT_EXPIRES_IN="7d"

# --- SMTP / Email ---
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="noreply@example.com"
SMTP_PASSWORD="your-smtp-password"
SMTP_FROM_NAME="Heavenly Events"
SMTP_FROM_EMAIL="noreply@heavenlyevents.lk"

# --- Google Maps ---
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# --- Analytics ---
NEXT_PUBLIC_GA_MEASUREMENT_ID=""
NEXT_PUBLIC_GTM_ID=""
NEXT_PUBLIC_META_PIXEL_ID=""

# --- Upload Settings ---
UPLOAD_DIR="./public/uploads"
UPLOAD_MAX_SIZE_MB=10

# --- Site Settings ---
NEXT_PUBLIC_APP_URL="https://your-domain.vercel.app"
NEXT_PUBLIC_SITE_NAME="Heavenly Events"
NEXT_PUBLIC_SITE_PHONE="+94777776357"
NEXT_PUBLIC_WHATSAPP="94777776357"
